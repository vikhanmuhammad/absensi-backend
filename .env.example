# Salin file ini menjadi .env lalu sesuaikan nilainya untuk environment lokal/staging/production.
# Jangan commit file .env (sudah masuk .gitignore).

# Koneksi database PostgreSQL — sesuaikan user, password, host, port, dan nama database.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/absensi_db?schema=public"

# Secret untuk signing JWT — ganti dengan string acak yang kuat (minimal 32 karakter) sebelum deploy.
JWT_SECRET="ganti-dengan-secret-yang-kuat"

# Masa berlaku token JWT, format library jsonwebtoken (contoh: 8h, 7d).
JWT_EXPIRES_IN="8h"

# Port HTTP server backend Express.
PORT=4000

# Origin frontend Angular yang diizinkan mengakses API (untuk konfigurasi CORS).
CORS_ORIGIN="http://localhost:4200"

# Folder/base URL untuk menyimpan file upload (foto profil karyawan, dokumen pendukung cuti).
UPLOAD_DIR="./uploads"
